{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/mascot/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Nunito|Fredoka))/i]",
        "message": "Font not provided by the design system. Available: Nunito, Fredoka."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|glow|bounce|disabled|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, glow, bounce, disabled, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|green|amber|orange|ghost|white)$/]",
        "message": "<Button> variant must be one of 'primary' | 'green' | 'amber' | 'orange' | 'ghost' | 'white'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg|pill)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg' | 'pill'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|radius|padding|children|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, radius, padding, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:white|warm|green|sky|dark)$/]",
        "message": "<Card> variant must be one of 'white' | 'warm' | 'green' | 'sky' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:sm|md|lg|xl)$/]",
        "message": "<Card> radius must be one of 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KrishMascot'] > JSXAttribute > JSXIdentifier[name!=/^(?:state|height|side|speech|animate|style|key|ref|className|style|children)$/]",
        "message": "<KrishMascot> doesn't accept that prop. Declared props: state, height, side, speech, animate, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KrishMascot'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:speaking|celebrate|think|thinking|mistake|point)$/]",
        "message": "<KrishMascot> state must be one of 'speaking' | 'celebrate' | 'think' | 'thinking' | 'mistake' | 'point'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KrishMascot'] > JSXAttribute[name.name='side'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<KrishMascot> side must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressDots'] > JSXAttribute > JSXIdentifier[name!=/^(?:total|current|onDotClick|style|key|ref|className|style|children)$/]",
        "message": "<ProgressDots> doesn't accept that prop. Declared props: total, current, onDotClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RoleBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|showIcon|size|filled|style|key|ref|className|style|children)$/]",
        "message": "<RoleBadge> doesn't accept that prop. Declared props: role, showIcon, size, filled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RoleBadge'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:sense|signal|think|act)$/]",
        "message": "<RoleBadge> role must be one of 'sense' | 'signal' | 'think' | 'act'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RoleBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<RoleBadge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpeechBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:side|animate|maxWidth|children|style|key|ref|className|style|children)$/]",
        "message": "<SpeechBubble> doesn't accept that prop. Declared props: side, animate, maxWidth, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpeechBubble'] > JSXAttribute[name.name='side'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<SpeechBubble> side must be one of 'left' | 'right'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
